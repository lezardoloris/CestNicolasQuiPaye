# Base de donnees (Docker Compose dev)
DATABASE_URL=postgresql://liberal:liberal@localhost:5433/liberal

# URL publique de l'application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret NextAuth (generer avec: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (optionnel pour le dev local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Webhook Secret (for contribution tracking)
GITHUB_WEBHOOK_SECRET=

# AI Context enrichment (optional — leave empty to use templates only)
MISTRAL_API_KEY=
# AI_MODEL=mistral-small-latest
# AI_DAILY_LIMIT=500
